{
  "kind": "collectionType",
  "collectionName": "clients",
  "info": {
    "singularName": "client",
    "pluralName": "clients",
    "displayName": "Client"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "companyName": {
      "type": "string"
    },
    "ownerName": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "phone": {
      "type": "text"
    },
    "website": {
      "type": "string"
    },
    "contactList": {
      "type": "component",
      "component": "contact.contacts",
      "repeatable": true
    },
    "jobs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::job.job",
      "mappedBy": "client"
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "countryList": {
      "type": "string"
    },
    "industriesList": {
      "type": "string"
    },
    "companySizeList": {
      "type": "string"
    },
    "shortDescription": {
      "type": "text"
    },
    "privateNote": {
      "type": "text"
    },
    "statusList": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "default": "client"
    }
  }
}
